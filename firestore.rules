rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isSuperAdmin() {
      return isSignedIn() && request.auth.token.email in ['rodrigo.frende@gmail.com'];
    }

    function gymDoc(gymId) {
      return get(/databases/$(database)/documents/gyms/$(gymId));
    }

    function gymAdminUids(gymId) {
      return gymDoc(gymId).data.get('adminUids', []);
    }

    function userGymMembership(gymId) {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)/gymMemberships/$(gymId));
    }

    function isGymAdmin(gymId) {
      return isSuperAdmin()
        || (isSignedIn() && request.auth.uid in gymAdminUids(gymId))
        || (isSignedIn()
          && exists(/databases/$(database)/documents/users/$(request.auth.uid)/gymMemberships/$(gymId))
          && userGymMembership(gymId).data.role == 'admin');
    }

    function isGymMember(gymId) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid)/gymMemberships/$(gymId));
    }

    function canAccessGym(gymId) {
      return isGymAdmin(gymId) || isGymMember(gymId);
    }

    function isClaimingMembership() {
      return isSignedIn()
        && resource.data.uid == ''
        && resource.data.email == request.auth.token.email
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['uid']);
    }

    function isSelfProfileEdit() {
      return isSignedIn()
        && resource.data.uid == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['fullName', 'phone', 'birthDate', 'photoURL']);
    }

    function isSelfAuthStatusUpdate() {
      return isSignedIn()
        && resource.data.uid == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['authStatus', 'passwordUpdatedAt', 'passwordResetRequestedAt']);
    }

    // ---- Perfil global ----
    match /users/{uid} {
      allow read: if isSignedIn() && (request.auth.uid == uid || isSuperAdmin());
      allow write: if isSignedIn() && request.auth.uid == uid;

      match /gymMemberships/{gymId} {
        allow read: if isSignedIn() && request.auth.uid == uid;
        allow write: if isSuperAdmin()
          || isGymAdmin(gymId)
          || (isSignedIn()
              && request.auth.uid == uid
              && request.resource.data.keys().hasOnly(['memberId', 'role']));
      }
    }

    // ---- Planes de suscripción (catálogo de la plataforma) ----
    match /plans/{planId} {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin();
    }

    match /memberLoginIndex/{emailKey} {
      allow get: if true;
      allow list: if false;
      allow create, update: if isGymAdmin(request.resource.data.gymId)
        || (isSignedIn()
          && get(/databases/$(database)/documents/gyms/$(request.resource.data.gymId)/members/$(request.resource.data.memberId)).data.uid == request.auth.uid);
      allow delete: if isGymAdmin(resource.data.gymId);
    }

    match /gyms/{gymId} {
      allow read: if canAccessGym(gymId) || isSuperAdmin();
      allow create: if isSuperAdmin();
      allow update, delete: if isGymAdmin(gymId) || isSuperAdmin();

      // ---- Socios / membresías ----
      match /members/{memberId} {
        allow read: if isGymAdmin(gymId)
          || (isSignedIn() && resource.data.uid == request.auth.uid)
          || (isSignedIn() && resource.data.email == request.auth.token.email);

        allow create, delete: if isGymAdmin(gymId);

        allow update: if isGymAdmin(gymId)
          || isClaimingMembership()
          || isSelfProfileEdit()
          || isSelfAuthStatusUpdate();

        match /notes/{noteId} {
          allow read, write: if isGymAdmin(gymId);
        }

        match /logs/{logId} {
          allow read: if isGymAdmin(gymId)
            || get(/databases/$(database)/documents/gyms/$(gymId)/members/$(memberId)).data.uid == request.auth.uid;
          allow create, update, delete: if get(/databases/$(database)/documents/gyms/$(gymId)/members/$(memberId)).data.uid == request.auth.uid;
        }

        match /payments/{paymentId} {
          allow read: if isGymAdmin(gymId)
            || (isSignedIn() && get(/databases/$(database)/documents/gyms/$(gymId)/members/$(memberId)).data.uid == request.auth.uid);
          allow write: if isGymAdmin(gymId);
        }
      }

      match /tariffs/{tariffId} {
        allow read: if canAccessGym(gymId);
        allow write: if isGymAdmin(gymId);
      }

      match /routines/{routineId} {
        allow read: if canAccessGym(gymId);
        allow write: if isGymAdmin(gymId);
      }

      match /exercises/{exerciseId} {
        allow read: if canAccessGym(gymId);
        allow write: if isGymAdmin(gymId);
      }

      match /assignments/{assignmentId} {
        allow read: if canAccessGym(gymId);
        allow write: if isGymAdmin(gymId);
      }

      match /attendance/{attendanceId} {
        allow get: if isGymAdmin(gymId)
          || (isSignedIn()
            && exists(/databases/$(database)/documents/gyms/$(gymId)/attendance/$(attendanceId))
            && resource.data.memberUid == request.auth.uid)
          || (isSignedIn()
            && !exists(/databases/$(database)/documents/gyms/$(gymId)/attendance/$(attendanceId))
            && isGymMember(gymId));
        allow list: if isGymAdmin(gymId);
        allow create, update: if isSignedIn()
          && request.resource.data.memberUid == request.auth.uid
          && exists(/databases/$(database)/documents/gyms/$(gymId)/members/$(request.resource.data.memberId))
          && get(/databases/$(database)/documents/gyms/$(gymId)/members/$(request.resource.data.memberId)).data.uid == request.auth.uid;
      }

      match /payments/{paymentId} {
        allow read: if isGymAdmin(gymId) || isSuperAdmin();
        allow write: if isSuperAdmin();
      }

      match /stats/{docId} {
        allow read, write: if isGymAdmin(gymId);
      }
    }
  }
}
