rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // Super-admin de la plataforma: custom claim seteado vía Admin SDK
    // (scripts/set-super-admin.mjs). El claim viaja firmado en el token, así que
    // no hay identidad hardcodeada acá ni en el bundle del cliente.
    function isSuperAdmin() {
      return isSignedIn() && request.auth.token.superAdmin == true;
    }

    function gymDoc(gymId) {
      return get(/databases/$(database)/documents/gyms/$(gymId));
    }

    function gymAdminUids(gymId) {
      return gymDoc(gymId).data.get('adminUids', []);
    }

    function userGymMembership(gymId) {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)/gymMemberships/$(gymId));
    }

    function isGymAdmin(gymId) {
      return isSuperAdmin()
        || (isSignedIn() && request.auth.uid in gymAdminUids(gymId))
        || (isSignedIn()
          && exists(/databases/$(database)/documents/users/$(request.auth.uid)/gymMemberships/$(gymId))
          && userGymMembership(gymId).data.role == 'admin');
    }

    function isGymMember(gymId) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid)/gymMemberships/$(gymId));
    }

    function canAccessGym(gymId) {
      return isGymAdmin(gymId) || isGymMember(gymId);
    }

    function isClaimingMembership() {
      return isSignedIn()
        && resource.data.uid == ''
        && resource.data.email == request.auth.token.email
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['uid']);
    }

    function isSelfProfileEdit() {
      return isSignedIn()
        && resource.data.uid == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['fullName', 'phone', 'birthDate', 'photoURL']);
    }

    function isSelfAuthStatusUpdate() {
      return isSignedIn()
        && resource.data.uid == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['authStatus', 'passwordUpdatedAt', 'passwordResetRequestedAt']);
    }

    // ---- Perfil global ----
    match /users/{uid} {
      allow read: if isSignedIn() && (request.auth.uid == uid || isSuperAdmin());
      allow write: if isSignedIn() && request.auth.uid == uid;

      match /gymMemberships/{gymId} {
        allow read: if isSignedIn() && request.auth.uid == uid;
        // El propio usuario solo puede escribir su índice de membresía si refleja
        // fielmente un member doc que ya reclamó: mismo uid y MISMO role. El role
        // lo controla exclusivamente un admin (las ramas self-edit del member no
        // tocan `role`), así que esto impide auto-asignarse `role: 'admin'`.
        allow write: if isSuperAdmin()
          || isGymAdmin(gymId)
          || (isSignedIn()
              && request.auth.uid == uid
              && request.resource.data.keys().hasOnly(['memberId', 'role'])
              && exists(/databases/$(database)/documents/gyms/$(gymId)/members/$(request.resource.data.memberId))
              && get(/databases/$(database)/documents/gyms/$(gymId)/members/$(request.resource.data.memberId)).data.uid == request.auth.uid
              && get(/databases/$(database)/documents/gyms/$(gymId)/members/$(request.resource.data.memberId)).data.role == request.resource.data.role);
      }
    }

    // ---- Planes de suscripción (catálogo de la plataforma) ----
    match /plans/{planId} {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin();
    }

    // Índice de lookup por email para el login (legible sin auth para poder rutear
    // el flujo antes de autenticar). Como es world-readable, la forma se valida en
    // escritura para que NO contenga PII de más (nombre completo, rol): solo lo
    // mínimo que el login necesita.
    match /memberLoginIndex/{emailKey} {
      function validLoginIndex() {
        let d = request.resource.data;
        return d.keys().hasOnly(['email', 'gymId', 'gymName', 'memberId', 'authStatus'])
          && (!('email' in d) || (d.email is string && d.email.size() <= 200))
          && (!('gymId' in d) || (d.gymId is string && d.gymId.size() <= 200))
          && (!('gymName' in d) || (d.gymName is string && d.gymName.size() <= 120))
          && (!('memberId' in d) || (d.memberId is string && d.memberId.size() <= 200))
          && (!('authStatus' in d) || (d.authStatus is string && d.authStatus.size() <= 40));
      }
      allow get: if true;
      allow list: if false;
      allow create, update: if validLoginIndex()
        && (isGymAdmin(request.resource.data.gymId)
          || (isSignedIn()
            && get(/databases/$(database)/documents/gyms/$(request.resource.data.gymId)/members/$(request.resource.data.memberId)).data.uid == request.auth.uid));
      allow delete: if isGymAdmin(resource.data.gymId);
    }

    // ---- Presentación pública del gym (para prospectos, sin login) ----
    // Legible por cualquiera; escribible solo por admin del gym o super-admin.
    // NO contiene datos sensibles: snapshot de marca + datos de contacto públicos.
    // Como es de lectura pública, validamos forma y tamaños para que un admin no
    // pueda escribir campos arbitrarios ni payloads enormes en un doc world-readable.
    match /publicProfiles/{gymId} {
      function validPresentation() {
        let d = request.resource.data;
        return d.keys().hasOnly([
            'id', 'name', 'logoURL', 'theme', 'description', 'videos', 'links', 'tariffs', 'sponsors',
            'whatsapp', 'email', 'address', 'openingHours',
            'videoURL', 'instagramURL', 'facebookURL', 'updatedAt'
          ])
          && (!('name' in d) || (d.name is string && d.name.size() <= 120))
          && (!('description' in d) || (d.description is string && d.description.size() <= 2000))
          && (!('videos' in d) || (d.videos is list && d.videos.size() <= 6))
          && (!('links' in d) || (d.links is list && d.links.size() <= 12))
          && (!('tariffs' in d) || (d.tariffs is list && d.tariffs.size() <= 20))
          && (!('sponsors' in d) || (d.sponsors is list && d.sponsors.size() <= 24))
          && (!('whatsapp' in d) || (d.whatsapp is string && d.whatsapp.size() <= 40))
          && (!('email' in d) || (d.email is string && d.email.size() <= 200))
          && (!('address' in d) || (d.address is string && d.address.size() <= 200))
          && (!('openingHours' in d) || (d.openingHours is string && d.openingHours.size() <= 200))
          && (!('logoURL' in d) || (d.logoURL is string && d.logoURL.size() <= 153600
              && d.logoURL.matches('data:image/(png|jpeg|webp);base64,.*')));
      }
      // El logo del perfil público debe reflejar el de `gyms/{gymId}` (que ya está
      // rate-limiteado). Así el mirror world-readable hereda el límite sin duplicar
      // contadores, y no puede divergir del logo real.
      function logoMirrorsGym() {
        let d = request.resource.data;
        return !('logoURL' in d)
          || (resource != null && !d.diff(resource.data).affectedKeys().hasAny(['logoURL']))
          || (exists(/databases/$(database)/documents/gyms/$(gymId))
              && d.logoURL == gymDoc(gymId).data.get('logoURL', null));
      }
      allow read: if true;
      allow create, update: if isGymAdmin(gymId) && validPresentation() && logoMirrorsGym();
      allow delete: if isGymAdmin(gymId);
    }

    match /gyms/{gymId} {
      // Rate-limit del logo: máximo 3 cambios por ventana fija de 24hs, y tope de
      // tamaño del data URL (el logo se guarda inline como string en el doc).
      // El cliente manda logoWindowStart (serverTimestamp) + logoChangeCount.
      function logoLimitOk() {
        let d = request.resource.data;
        return !d.diff(resource.data).affectedKeys().hasAny(['logoURL'])
          || (
            (!('logoURL' in d) || (d.logoURL is string && d.logoURL.size() <= 153600
              && d.logoURL.matches('data:image/(png|jpeg|webp);base64,.*')))
            && (
              // Ventana nueva: primera vez o la anterior ya venció.
              (d.get('logoWindowStart', null) == request.time
                && d.get('logoChangeCount', 99) == 1
                && (!('logoWindowStart' in resource.data)
                  || resource.data.logoWindowStart + duration.value(24, 'h') < request.time))
              ||
              // Misma ventana: suma exactamente 1, hasta 3.
              (d.get('logoWindowStart', null) == resource.data.get('logoWindowStart', null)
                && d.get('logoChangeCount', 99) == resource.data.get('logoChangeCount', 0) + 1
                && d.get('logoChangeCount', 99) <= 3)
            )
          );
      }

      allow read: if canAccessGym(gymId) || isSuperAdmin();
      allow create: if isSuperAdmin();
      allow update: if (isGymAdmin(gymId) && logoLimitOk()) || isSuperAdmin();
      allow delete: if isGymAdmin(gymId) || isSuperAdmin();

      // ---- Socios / membresías ----
      match /members/{memberId} {
        allow read: if isGymAdmin(gymId)
          || (isSignedIn() && resource.data.uid == request.auth.uid)
          || (isSignedIn() && resource.data.email == request.auth.token.email);

        allow create, delete: if isGymAdmin(gymId);

        allow update: if isGymAdmin(gymId)
          || isClaimingMembership()
          || isSelfProfileEdit()
          || isSelfAuthStatusUpdate();

        match /notes/{noteId} {
          allow read, write: if isGymAdmin(gymId);
        }

        match /logs/{logId} {
          allow read: if isGymAdmin(gymId)
            || get(/databases/$(database)/documents/gyms/$(gymId)/members/$(memberId)).data.uid == request.auth.uid;
          allow create, update, delete: if get(/databases/$(database)/documents/gyms/$(gymId)/members/$(memberId)).data.uid == request.auth.uid;
        }

        match /payments/{paymentId} {
          allow read: if isGymAdmin(gymId)
            || (isSignedIn() && get(/databases/$(database)/documents/gyms/$(gymId)/members/$(memberId)).data.uid == request.auth.uid);
          allow write: if isGymAdmin(gymId);
        }
      }

      match /tariffs/{tariffId} {
        allow read: if canAccessGym(gymId);
        allow write: if isGymAdmin(gymId);
      }

      match /routines/{routineId} {
        allow read: if canAccessGym(gymId);
        allow write: if isGymAdmin(gymId);
      }

      match /exercises/{exerciseId} {
        allow read: if canAccessGym(gymId);
        allow write: if isGymAdmin(gymId);
      }

      match /assignments/{assignmentId} {
        allow read: if canAccessGym(gymId);
        allow write: if isGymAdmin(gymId);
      }

      match /attendance/{attendanceId} {
        allow get: if isGymAdmin(gymId)
          || (isSignedIn()
            && exists(/databases/$(database)/documents/gyms/$(gymId)/attendance/$(attendanceId))
            && resource.data.memberUid == request.auth.uid)
          || (isSignedIn()
            && !exists(/databases/$(database)/documents/gyms/$(gymId)/attendance/$(attendanceId))
            && isGymMember(gymId));
        allow list: if isGymAdmin(gymId);
        allow create, update: if isSignedIn()
          && request.resource.data.memberUid == request.auth.uid
          && exists(/databases/$(database)/documents/gyms/$(gymId)/members/$(request.resource.data.memberId))
          && get(/databases/$(database)/documents/gyms/$(gymId)/members/$(request.resource.data.memberId)).data.uid == request.auth.uid;
      }

      match /payments/{paymentId} {
        allow read: if isGymAdmin(gymId) || isSuperAdmin();
        allow write: if isSuperAdmin();
      }

      match /stats/{docId} {
        allow read, write: if isGymAdmin(gymId);
      }
    }
  }
}
